# Kick
KICK_CHANNEL=your-channel
KICK_CHATROOM_ID=               # Optional — auto-resolves from channel

# LLM
GEMINI_API_KEY=your-key         # Default provider
# ANTHROPIC_API_KEY=            # Alternative provider

# TTS
TTS_PROVIDER=fish               # fish | elevenlabs | openai
TTS_API_KEY=your-key

# Avatar
AVATAR_ENABLED=true
AVATAR_PORT=3939

# Broadcast (optional — use OBS for production)
BROADCAST_RTMP_URL=
BROADCAST_STREAM_KEY=

# Policy
POLICY_PRESET=safe-mode         # permissive | safe-mode | strict

# Audit
AUDIT_STORAGE=stdout            # memory | file | stdout
AUDIT_MAX_TRACES=10000
